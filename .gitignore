# ================================================================
# Supply Chain Control Tower — .gitignore
# Owner: Vishal
#
# This file tells Git which files to NEVER track or upload to GitHub.
# Even if you run "git add .", these files will be skipped automatically.
# ================================================================


# ── PRIVATE DATA — never put real operational data on GitHub ────────────────
data/supply_chain.db          # Your real SQLite database
data/*.db                     # Any SQLite database file
data/*.db-shm                 # SQLite shared memory file (auto-created)
data/*.db-wal                 # SQLite write-ahead log (auto-created)


# ── PRIVATE SETTINGS — contains your local Windows paths ────────────────────
config/settings.yaml          # Your real settings with local paths
                              # (settings.example.yaml is fine — that's the template)


# ── MEMORY SYSTEM — may contain conversation summaries ──────────────────────
memory/project_memory.json    # Claude's cross-session memory file


# ── LOGS — generated at runtime, not needed on GitHub ───────────────────────
logs/                         # Entire logs folder
*.log                         # Any .log file anywhere in the project


# ── PYTHON RUNTIME FILES — auto-generated, not your code ───────────────────
__pycache__/                  # Python's compiled bytecode cache folders
*.pyc                         # Compiled Python files
*.pyo                         # Optimised Python files
*.pyd                         # Python DLL files (Windows)
.Python                       # Python environment marker


# ── VIRTUAL ENVIRONMENT — your local Python packages ────────────────────────
venv/                         # Standard virtual environment folder name
.venv/                        # Alternative virtual environment name
env/                          # Another common name
ENV/                          # Uppercase variant


# ── CLAUDE DESKTOP CONFIG — contains your machine's paths ───────────────────
claude_desktop_config.json    # Never commit this — has local paths + setup


# ── WINDOWS SYSTEM FILES ─────────────────────────────────────────────────────
Thumbs.db                     # Windows thumbnail cache
Desktop.ini                   # Windows folder settings
$RECYCLE.BIN/                 # Windows recycle bin

# ── VS CODE EDITOR FILES ──────────────────────────────────────────────────────
.vscode/                      # VS Code workspace settings
*.code-workspace              # VS Code workspace file


# ── ENVIRONMENT VARIABLES ────────────────────────────────────────────────────
.env                          # Environment variables file (API keys, secrets)
.env.local
.env.production


# ── TEST ARTIFACTS ────────────────────────────────────────────────────────────
.pytest_cache/                # pytest cache folder
htmlcov/                      # Coverage HTML report folder
.coverage                     # Coverage data file


# ── OPERATING SYSTEM ─────────────────────────────────────────────────────────
.DS_Store                     # macOS folder metadata (if ever used on Mac)
